{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "allow": {
      "edit": "allow",
      "read": "allow",
      "glob": "allow",
      "grep": "allow",
      "list": "allow",
      "bash": {
        "*": "deny",
        "npm run dev": "allow",
        "npm install *": "allow",
        "npm run build": "allow",
        "node *": "allow",
        "cat *": "allow",
        "ls *": "allow"
      }
    },
    "external_directory": "deny"
  }
}